<extension xmlns="http://ns.adobe.com/air/extension/30.0">
  <id>com.myflashlab.air.extensions.admob</id>
  <versionNumber>6.2.0</versionNumber>
  <copyright>2020, MyFlashLabs Team. All rights reserved.</copyright>
  <description>
    <text xml:lang="en">Air Native Extension!</text>
  </description>
  <platforms>
    <platform name="Android-ARM64">
      <applicationDeployment>
        <nativeLibrary>classes.jar</nativeLibrary>
        <initializer>com.myflashlab.admob.MyExtension</initializer>
        <finalizer>com.myflashlab.admob.MyExtension</finalizer>
      </applicationDeployment>
    </platform>
    <platform name="Android-ARM">
      <applicationDeployment>
        <nativeLibrary>classes.jar</nativeLibrary>
        <initializer>com.myflashlab.admob.MyExtension</initializer>
        <finalizer>com.myflashlab.admob.MyExtension</finalizer>
      </applicationDeployment>
    </platform>
    <platform name="Android-x86">
      <applicationDeployment>
        <nativeLibrary>classes.jar</nativeLibrary>
        <initializer>com.myflashlab.admob.MyExtension</initializer>
        <finalizer>com.myflashlab.admob.MyExtension</finalizer>
      </applicationDeployment>
    </platform>
    <platform name="iPhone-ARM">
      <applicationDeployment>
        <nativeLibrary>libexAdMob.a</nativeLibrary>
        <initializer>comMyflashlabsAdMobMyExtensionInitializer</initializer>
        <finalizer>comMyflashlabsAdMobMyExtensionFinalizer</finalizer>
      </applicationDeployment>
    </platform>
    <platform name="default">
      <applicationDeployment />
    </platform>
  </platforms>
</extension>

